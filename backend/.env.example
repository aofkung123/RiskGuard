# RiskGuard Backend Configuration
# Copy this file to .env and fill in the values

# Database URL for PostgreSQL (Supabase)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Supabase API Settings (Optional - if using Supabase Python SDK for Auth/Storage)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-key

# App Security
SECRET_KEY=generate-a-secure-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
